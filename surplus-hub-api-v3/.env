# ===== Environment =====
APP_ENV=local  # local | dev | stage | prod

# ===== Application =====
PROJECT_NAME=Surplus Hub API
API_V1_STR=/api/v1

# ===== Database =====
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=surplushub
# Local Docker: port 5433 mapped from container
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/surplushub

# ===== Authentication =====
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== CORS =====
# Comma-separated list of allowed origins, or ["*"] for all
CORS_ORIGINS=["*"]

# ===== Clerk (Optional) =====
# CLERK_PEM_PUBLIC_KEY=

# ===== AWS S3 =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=surplus-hub-uploads
AWS_S3_REGION=ap-northeast-2

# ===== Firebase Cloud Messaging (Optional) =====
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# ===== Upload =====
MAX_UPLOAD_SIZE_MB=10

# ===== AI Services (Vertex AI) =====
AI_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=est-alan-451902
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/Users/jeongseongchae/dev/owner/service-account.json
