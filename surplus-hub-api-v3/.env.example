# ===== Environment =====
APP_ENV=local  # local | dev | stage | prod

# ===== Application =====
PROJECT_NAME=Surplus Hub API
API_V1_STR=/api/v1

# ===== Database =====
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=surplushub
# Optional: override with full URL
# DATABASE_URL=postgresql://user:password@host/dbname

# ===== Authentication =====
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== CORS =====
# Comma-separated list of allowed origins, or ["*"] for all
CORS_ORIGINS=["*"]

# ===== Clerk (Optional) =====
# CLERK_PEM_PUBLIC_KEY=

# ===== AWS S3 =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=surplus-hub-uploads
AWS_S3_REGION=ap-northeast-2

# ===== Firebase Cloud Messaging (Optional) =====
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# ===== Upload =====
MAX_UPLOAD_SIZE_MB=10

# ===== AI Services =====
# AI Provider toggle: "default" (OpenAI+Gemini Dev) or "vertex" (Vertex AI)
AI_PROVIDER=default
# Google Gemini API Key (for image analysis, used when AI_PROVIDER=default)
# GOOGLE_AI_API_KEY=your-google-ai-api-key
# Google Cloud settings (used when AI_PROVIDER=vertex)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=asia-northeast3
# OpenAI API Key (for text generation, used when AI_PROVIDER=default)
# OPENAI_API_KEY=your-openai-api-key
# Embedding model (default: BAAI/bge-m3)
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # default, used when APP_ENV != local
